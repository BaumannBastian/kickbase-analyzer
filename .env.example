# ------------------------------------
# .env.example
#
# Beispielkonfiguration fuer lokalen Private-Mode.
# Werte muessen in `.env` mit echten Zugangsdaten gepflegt werden.
# ------------------------------------

# Runtime mode
MODE=demo
TIMEZONE=Europe/Berlin
SOURCE_VERSION=private-v1

# Kickbase private mode
KICKBASE_BASE_URL=https://api.kickbase.com
KICKBASE_LEAGUE_ID=replace_with_league_id
KICKBASE_EMAIL=replace_with_email
KICKBASE_PASSWORD=replace_with_password
KICKBASE_USER_AGENT=okhttp/4.11.0

# API paths (defaults are valid for the runner, can be overridden)
KICKBASE_AUTH_PATH=/v4/user/login
KICKBASE_AUTH_EMAIL_FIELD=em
KICKBASE_AUTH_PASSWORD_FIELD=pass
KICKBASE_PLAYER_SNAPSHOT_PATH=/v4/leagues/{league_id}/market
# Voller Bundesliga-Spielerpool (empfohlen fuer universelle Tabelle):
# Competition-ID wird idealerweise automatisch aus dem Login (`srvl[].cpi`) erkannt.
# Optional kann sie explizit gesetzt werden (z.B. 1 fuer Bundesliga).
KICKBASE_COMPETITION_ID=
KICKBASE_COMPETITION_PLAYERS_SEARCH_PATH=/v4/competitions/{competition_id}/players/search
KICKBASE_COMPETITION_PLAYERS_PAGE_SIZE=100
KICKBASE_COMPETITION_PLAYERS_QUERY=
KICKBASE_MATCH_STATS_PATH=
KICKBASE_PLAYER_DETAILS_PATH=/v4/leagues/{league_id}/players/{player_id}
KICKBASE_PLAYER_MARKET_VALUE_HISTORY_PATH=/v4/players/{player_id}/market-value
KICKBASE_PLAYER_PERFORMANCE_PATH=/v4/players/{player_id}/performance
KICKBASE_PLAYER_TRANSFERS_PATH=/v4/leagues/{league_id}/players/{player_id}/transfers

# Runtime behavior
KICKBASE_TIMEOUT_SECONDS=20
KICKBASE_MAX_RETRIES=2
KICKBASE_BACKOFF_SECONDS=1
KICKBASE_RATE_LIMIT_SECONDS=0.25
KICKBASE_CACHE_DIR=data/cache/kickbase
KICKBASE_CACHE_TTL_SECONDS=300

# LigaInsider scrape (private mode only)
# Use one or multiple team lineup URLs (comma-separated).
# Example:
# LIGAINSIDER_STATUS_URL=https://www.ligainsider.de/fc-bayern-muenchen/1/,https://www.ligainsider.de/borussia-dortmund/14/
LIGAINSIDER_STATUS_URL=
LIGAINSIDER_USER_AGENT="kickbase-analyzer/0.1 (+private-use)"
LIGAINSIDER_TIMEOUT_SECONDS=20
LIGAINSIDER_MAX_RETRIES=2
LIGAINSIDER_BACKOFF_SECONDS=1
LIGAINSIDER_RATE_LIMIT_SECONDS=1.0

# Optional fallback file for LigaInsider status rows (overrides live scrape)
LIGAINSIDER_STATUS_FILE=

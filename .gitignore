# ------------------------------------
# .gitignore
#
# Ignorierte Artefakte fuer lokale Entwicklung und Laufzeitdaten.
# ------------------------------------

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Environments
.venv/
venv/
.env
.secrets/

# Build artifacts
build/
dist/
*.egg-info/

# Runtime outputs
data/bronze/*.ndjson
data/bronze/*.json
data/cache/
data/lakehouse/
data/marts/
data/backtesting/
data/warehouse/
data/history/
.cache/
out/

# Power BI Desktop local artifacts
dashboards/powerbi/local/**
!dashboards/powerbi/local/.gitkeep
dashboards/powerbi/**/*.pbix
dashboards/powerbi/**/*.pbit

# OS/editor
.DS_Store
.vscode/
.idea/
